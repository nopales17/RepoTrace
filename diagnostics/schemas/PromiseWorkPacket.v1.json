{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repotrace.local/diagnostics/schemas/PromiseWorkPacket.v1.json",
  "title": "PromiseWorkPacket.v1",
  "description": "Portable session-level bundle for one promise-scoped manual worker run.",
  "type": "object",
  "required": [
    "schema_version",
    "produced_by",
    "work_packet_id",
    "incident_id",
    "promise_id",
    "slice",
    "frame_ref",
    "task_ref",
    "touch_map_ref",
    "coverage_ref",
    "check_ids",
    "prior_outcome_refs",
    "objective",
    "current_pressure",
    "budget",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "PromiseWorkPacket.v1"
    },
    "produced_by": {
      "type": "string",
      "minLength": 1
    },
    "work_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "incident_id": {
      "type": "string",
      "minLength": 1
    },
    "promise_id": {
      "type": "string",
      "minLength": 1
    },
    "slice": {
      "type": "object",
      "required": [
        "interaction_family",
        "consistency_boundary"
      ],
      "properties": {
        "interaction_family": {
          "type": "string",
          "minLength": 1
        },
        "consistency_boundary": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "frame_ref": {
      "type": "string",
      "minLength": 1
    },
    "task_ref": {
      "type": "string",
      "minLength": 1
    },
    "touch_map_ref": {
      "type": "string",
      "minLength": 1
    },
    "coverage_ref": {
      "type": "string",
      "minLength": 1
    },
    "check_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prior_outcome_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "current_pressure": {
      "type": "object",
      "required": [
        "focus_statement",
        "violation_shape",
        "unresolved_questions",
        "next_check"
      ],
      "properties": {
        "focus_statement": {
          "type": "string",
          "minLength": 1
        },
        "violation_shape": {
          "type": "string",
          "minLength": 1
        },
        "unresolved_questions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "next_check": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "budget": {
      "type": "object"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "active",
        "blocked",
        "completed",
        "stale"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
