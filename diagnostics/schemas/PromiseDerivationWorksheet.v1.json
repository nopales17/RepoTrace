{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repotrace.local/diagnostics/schemas/PromiseDerivationWorksheet.v1.json",
  "title": "PromiseDerivationWorksheet.v1",
  "description": "Manual Stage 1 derivation worksheet used to propose promise-scoped contracts before PromiseRegistry seeding.",
  "type": "object",
  "required": [
    "schema_version",
    "produced_by",
    "worksheet_id",
    "system_name",
    "purpose",
    "actors",
    "assets_or_rights",
    "transition_families",
    "representations",
    "consistency_boundaries",
    "settlement_horizons",
    "admin_or_external_surfaces",
    "candidate_promises",
    "open_questions",
    "evidence_refs",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "PromiseDerivationWorksheet.v1"
    },
    "produced_by": {
      "type": "string",
      "minLength": 1
    },
    "worksheet_id": {
      "type": "string",
      "minLength": 1
    },
    "system_name": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assets_or_rights": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "transition_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "representations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "consistency_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "settlement_horizons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "admin_or_external_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "candidate_promises": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "statement",
          "actor_scope",
          "protected_state",
          "interaction_families",
          "consistency_boundaries",
          "rationale",
          "priority",
          "confidence",
          "status"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "actor_scope": {
            "type": "string",
            "minLength": 1
          },
          "protected_state": {
            "type": "string",
            "minLength": 1
          },
          "interaction_families": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "consistency_boundaries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "proposed",
              "accepted",
              "rejected",
              "deferred"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "object"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "in_review",
        "accepted"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
