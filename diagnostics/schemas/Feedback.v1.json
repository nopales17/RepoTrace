{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repotrace.local/diagnostics/schemas/Feedback.v1.json",
  "title": "Feedback.v1",
  "type": "object",
  "required": [
    "schema_version",
    "produced_by",
    "feedback_id",
    "incident_id",
    "retrieval_attempt_id",
    "verdict_assessment",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "Feedback.v1"
    },
    "produced_by": {
      "type": "string",
      "minLength": 1
    },
    "feedback_id": {
      "type": "string",
      "minLength": 1
    },
    "incident_id": {
      "type": "string",
      "minLength": 1
    },
    "retrieval_attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "verdict_assessment": {
      "type": "string",
      "enum": [
        "confirm",
        "revise",
        "reject"
      ]
    },
    "notes": {
      "type": "string"
    },
    "verifier_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
